generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Utilisateurs
model Utilisateur {
  id         Int      @id @default(autoincrement())
  prenom     String
  nom        String
  email      String   @unique
  telephone  String?
  motDePasse String
  role       String   @default("caissier")
  actif      Boolean  @default(true)
  droits     Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  ventes Vente[]
}

// ─── Catégories
model Categorie {
  id       Int       @id @default(autoincrement())
  nom      String    @unique
  produits Produit[]
}

// ─── Fournisseurs
model Fournisseur {
  id             Int        @id @default(autoincrement())
  nom            String
  contact        String?
  telephone      String?
  email          String?
  adresse        String?
  categorie      String?
  delaiLivraison Int        @default(1)
  statut         String     @default("actif")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  commandes Commande[]
  produits  Produit[]
}

// ─── Produits
model Produit {
  id            Int          @id @default(autoincrement())
  ref           String       @unique
  nom           String
  categorieId   Int?
  categorie     Categorie?   @relation(fields: [categorieId], references: [id])
  fournisseurId Int?
  fournisseur   Fournisseur? @relation(fields: [fournisseurId], references: [id])
  stock         Int          @default(0)
  seuil         Int          @default(10)
  prix          Float
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  lignesVente    LigneVente[]
  lignesCommande LigneCommande[]
}

// ─── Clients
model Client {
  id        Int      @id @default(autoincrement())
  nom       String
  telephone String?
  email     String?
  adresse   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ventes Vente[]
}

// ─── Ventes
model Vente {
  id            Int          @id @default(autoincrement())
  numero        String       @unique
  clientId      Int?
  client        Client?      @relation(fields: [clientId], references: [id])
  utilisateurId Int?
  utilisateur   Utilisateur? @relation(fields: [utilisateurId], references: [id])
  sousTotal     Float
  tva           Float
  total         Float
  createdAt     DateTime     @default(now())

  lignes LigneVente[]
}

// ─── Lignes de vente
model LigneVente {
  id        Int     @id @default(autoincrement())
  venteId   Int
  vente     Vente   @relation(fields: [venteId], references: [id])
  produitId Int
  produit   Produit @relation(fields: [produitId], references: [id])
  quantite  Int
  prix      Float
  total     Float
}

// ─── Commandes fournisseurs
model Commande {
  id            Int             @id @default(autoincrement())
  numero        String          @unique
  fournisseurId Int
  fournisseur   Fournisseur     @relation(fields: [fournisseurId], references: [id])
  date          DateTime        @default(now())
  dateLivraison DateTime?
  montant       Float           @default(0)
  statut        String          @default("en_attente")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  lignes LigneCommande[]
}

// ─── Lignes de commande
model LigneCommande {
  id         Int      @id @default(autoincrement())
  commandeId Int
  commande   Commande @relation(fields: [commandeId], references: [id])
  produitId  Int
  produit    Produit  @relation(fields: [produitId], references: [id])
  quantite   Int
  prix       Float
  total      Float
}